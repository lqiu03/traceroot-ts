{
  "name": "@traceroot-ai/cursor",
  "version": "0.1.0",
  "description": "OpenTelemetry instrumentation for the Cursor Agent SDK",
  "keywords": [
    "traceroot",
    "cursor",
    "cursor-sdk",
    "observability",
    "opentelemetry",
    "agent",
    "tracing"
  ],
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "package.json"
  ],
  "exports": {
    ".": {
      "require": "./dist/index.js",
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/traceroot-ai/traceroot-ts.git"
  },
  "homepage": "https://traceroot.ai",
  "bugs": {
    "url": "https://github.com/traceroot-ai/traceroot-ts/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-proto": "^0.57.2",
    "@opentelemetry/sdk-trace-base": "^1.30.1",
    "zod": "^3.23.0"
  },
  "peerDependencies": {
    "@cursor/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@cursor/sdk": "^1.0.10",
    "@types/node": "^20.0.0",
    "dotenv": "^16.4.5",
    "tsx": "^4.19.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  }
}
